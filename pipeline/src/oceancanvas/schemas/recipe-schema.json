{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oceancanvas.dev/schemas/recipe.json",
  "title": "OceanCanvas Recipe",
  "description": "A recipe defining how ocean data becomes daily generative art. Schema per RFC-001.",
  "type": "object",
  "required": ["name", "region", "sources", "render"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "description": "Kebab-case slug. Filesystem-safe, stable after creation."
    },
    "region": {
      "type": "object",
      "required": ["lat", "lon"],
      "properties": {
        "lat": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "lon": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "name": { "type": "string" }
      }
    },
    "sources": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string" },
        "context": { "type": "string" },
        "audio": { "type": "string" }
      }
    },
    "schedule": {
      "type": "string",
      "enum": ["daily", "manual"],
      "default": "daily"
    },
    "render": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["field", "particles", "scatter"]
        },
        "colormap": { "type": "string" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "smooth": { "type": "boolean" },
        "seed": { "type": "integer" }
      }
    }
  }
}
